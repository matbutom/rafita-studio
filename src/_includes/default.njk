<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>{% if title %}{{ title }} | {% endif %}Rafita Studio</title>
  <!-- Agregar Google Font (opcional si lo necesitas) -->
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;700&display=swap" rel="stylesheet">
  <style>
    /* Aplicar la fuente sans-serif 'Roboto' (opcional) */
    body {
      font-family: 'Roboto', sans-serif;
      margin: 0;
      padding: 0;
      text-align: center; /* Centrar todo el contenido */
    }

    /* Estilos para el logo */
    header {
      margin-top: 30px; /* Espacio en la parte superior */
      margin-left: 30px;
      text-align: left;
    }

    header img {
      width: 200px; /* Ajusta el tamaño del logo */
